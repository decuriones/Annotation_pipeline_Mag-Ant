params {
    // Path to the fasta sequences in an array format
    seq_list = []
    // Project name for taxonomy collection output
    project = "viral_check"
    // Whether to enable all processes or only genomad
    viral_verify = true
}

apptainer.enabled = true

process {

    withName : 'Merging_summaries' {
    executor = 'local'
    }

    withName : 'GeNOMAD_process' {
    executor = 'slurm' 
    cpus = 8
    memory = '20 GB'
    time = '48h' 
    }

    withName : 'Viral_verify_process' {
    executor = 'slurm'
    cpus = 8
    memory = '20 GB'
    time = '48h'    
    }
}
