params {
     // Path to the fasta sequences in an array format
    seq_list = List
    // Path to metadata file containing the genus information for PGAP annotation
    tax_gtdb = ''
    // Project name for taxonomy collection output
    project = 'Annotation_project'
    // Annotation tool to use (PGAP or Bakta)
    annotation_tool = 'Bakta' // Default to Bakta, but can be set to PGAP using the pgap profile
    // Boolean parameter to decide whether to run Antismash annotation
    antismash = true // Default to true, but can be set to false if Antismash annotation is not needed
}

apptainer.enabled = true

process {


    withName : 'PGAP_annotation' {
         executor = 'slurm' 
         cpus = 16
         memory = '160 GB'
         time = '48h'
    }
    
    withName : 'Bakta_annotation' {
         executor = 'slurm'
         cpus = 8
         memory = '64 GB'
         time = '48h'
    }

    withName : 'Python_taxonomy_comparison' { 
         executor = 'local'
    }

    withName : 'Antismash_annotation' {
         executor = 'slurm'
         cpus = 16
         memory = '100 GB'
         time = '48h'
    }
}
profiles {
    standard {
        process.executor = 'local'
    }
    pgap {
     if (params.annotation_tool != 'PGAP') {
            println "WARNING: Setting annotation_tool to 'PGAP' because Pgap profile is used"
            params.annotation_tool = 'PGAP'
        }
     if (!params.tax_gtdb){
            error "WARNING: tax_gtdb parameter is not set, but PGAP profile is used. Please provide a path to the GTDB-Tk classification file."
        }
        process.executor = 'slurm'
    }
    bakta {
     if (params.annotation_tool != 'Bakta') {
            println "WARNING: Setting annotation_tool to 'Bakta' because bakta profile is used"
            params.annotation_tool = 'Bakta'
        }
        process.executor = 'slurm'
    }
    taxonomy_usage {
     if (!params.tax_gtdb){
            error "WARNING: tax_gtdb parameter is not set, but Taxonomy_usage profile is used. Please provide a path to the GTDB-Tk classification file."
        }
    }

}