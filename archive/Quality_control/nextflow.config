params {
    busco = true // Default to true, but can be set to false if Busco annotation is not needed
    protein_fasta = '/home/elouanln/projects/def-jcomte/elouanln/Sandbox/Data/Bakta_annotation_out/Bakta_output/CIMP_02_A3_annotation_output/CIMP_02_A3.faa' // Path to the protein fasta file for quality control, to be defined when the quality control module will be ready
    seq_name = 'CIMP_02_A3'
    busco_lineage = 'Cyanobacteria_odb12'
    project = 'Test_project'
}

apptainer.enabled = true

process {

    withName: 'Busco_process' {
        executor = 'slurm'
        cpus = 8
        memory = '30 GB'
        time = '48h'

    }
}

